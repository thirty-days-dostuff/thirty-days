@page "/"
@inject LocalizationService Loc
@implements IDisposable

<PageTitle>@Loc.StartPageTitle</PageTitle>

<div class="form-page">
    <label class="language-switcher">
        @Loc.LanguageLabel
        <select value="@LanguageValue" @onchange="OnLanguageChanged">
            <option value="de">Deutsch</option>
            <option value="en">English</option>
        </select>
    </label>

    <h1>@Loc.StartPageTitle</h1>

    <AuthorizeView>
        <Authorized>
            <p>@Loc.LoginSuccessMessage</p>
        </Authorized>
        <NotAuthorized>
            <a class="link-button" href="/Account/Login">@Loc.LoginButtonText</a>
        </NotAuthorized>
    </AuthorizeView>
</div>

@code {
    private string LanguageValue => Loc.Language == AppLanguage.German ? "de" : "en";

    protected override void OnInitialized()
    {
        Loc.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        Loc.OnChange -= StateHasChanged;
    }

    private void OnLanguageChanged(ChangeEventArgs e)
    {
        Loc.Language = (string?)e.Value == "de" ? AppLanguage.German : AppLanguage.English;
    }
}
