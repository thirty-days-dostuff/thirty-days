@page "/register"
@attribute [Authorize]
@inject HttpClient Http
@inject LocalizationService Loc
@implements IDisposable

<PageTitle>@Loc.RegistrationPageTitle</PageTitle>

<div class="form-page">
    <h1>@Loc.RegistrationPageTitle</h1>

    @if (!string.IsNullOrEmpty(_message))
    {
        <p class="@(_isError ? "message-error" : "message-success")">@_message</p>
    }

    <input placeholder="@Loc.FirstNamePlaceholder" @bind="_firstName" @bind:event="oninput" />
    <input placeholder="@Loc.LastNamePlaceholder" @bind="_lastName" @bind:event="oninput" />
    <input type="date" placeholder="@Loc.DateOfBirthPlaceholder" @bind="_dateOfBirth" />

    <button @onclick="OnRegisterNowClicked">@Loc.RegisterNowButtonText</button>
</div>

@code {
    private string _firstName = string.Empty;
    private string _lastName = string.Empty;
    private DateTime _dateOfBirth = DateTime.Today;
    private string? _message;
    private bool _isError;

    protected override void OnInitialized()
    {
        Loc.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        Loc.OnChange -= StateHasChanged;
    }

    private async Task OnRegisterNowClicked()
    {
        var response = await Http.PostAsJsonAsync("api/users/register", new RegisterRequest(
            _firstName.Trim(), _lastName.Trim(), _dateOfBirth));

        var result = await response.Content.ReadFromJsonAsync<RegisterResponse>();

        _isError = result?.Success != true;
        _message = _isError ? null : Loc.RegistrationSuccessMessage;
    }
}
