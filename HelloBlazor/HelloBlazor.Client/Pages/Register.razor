@page "/register"
@attribute [Authorize]
@inject HttpClient Http
@inject LocalizationService Loc
@implements IDisposable

<PageTitle>@Loc.RegistrationPageTitle</PageTitle>

<div class="form-page">
    <h1>@Loc.RegistrationPageTitle</h1>

    @if (!string.IsNullOrEmpty(_message))
    {
        <p class="@(_isError ? "message-error" : "message-success")">@_message</p>
    }

    <input placeholder="@Loc.FirstNamePlaceholder" @bind="_firstName" @bind:event="oninput" />
    <input placeholder="@Loc.LastNamePlaceholder" @bind="_lastName" @bind:event="oninput" />
    <input type="date" placeholder="@Loc.DateOfBirthPlaceholder" @bind="_dateOfBirth" />

    <select @bind="_gender" aria-label="@Loc.GenderPlaceholder">
        @foreach (var gender in Enum.GetValues<Gender>())
        {
            <option value="@gender">@Loc.GenderName(gender)</option>
        }
    </select>

    <fieldset>
        <legend>@Loc.InterestedInPlaceholder</legend>
        @foreach (var interest in InterestOptions)
        {
            <label>
                <input type="checkbox" checked="@_interestedIn.Contains(interest)"
                       @onchange="@(e => ToggleInterest(interest, (bool)e.Value!))" />
                @Loc.InterestName(interest)
            </label>
        }
    </fieldset>

    <button @onclick="OnRegisterNowClicked">@Loc.RegisterNowButtonText</button>
</div>

@code {
    private string _firstName = string.Empty;
    private string _lastName = string.Empty;
    private DateTime _dateOfBirth = DateTime.Today;
    private Gender _gender = Gender.Male;
    private readonly HashSet<GenderInterest> _interestedIn = [];
    private string? _message;
    private bool _isError;

    private static readonly GenderInterest[] InterestOptions =
        [GenderInterest.Male, GenderInterest.Female, GenderInterest.Diverse];

    private void ToggleInterest(GenderInterest interest, bool isChecked)
    {
        if (isChecked)
            _interestedIn.Add(interest);
        else
            _interestedIn.Remove(interest);
    }

    protected override void OnInitialized()
    {
        Loc.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        Loc.OnChange -= StateHasChanged;
    }

    private async Task OnRegisterNowClicked()
    {
        var interestedIn = _interestedIn.Aggregate(GenderInterest.None, (acc, interest) => acc | interest);

        var response = await Http.PostAsJsonAsync("api/users/register", new RegisterRequest(
            _firstName.Trim(), _lastName.Trim(), _dateOfBirth, _gender, interestedIn));

        var result = await response.Content.ReadFromJsonAsync<RegisterResponse>();

        _isError = result?.Success != true;
        _message = _isError ? null : Loc.RegistrationSuccessMessage;
    }
}
