@page "/register"
@attribute [Authorize]
@inject HttpClient Http
@inject LocalizationService Loc
@implements IDisposable

<PageTitle>@Loc.RegistrationPageTitle</PageTitle>

<div class="form-page">
    <h1>@Loc.RegistrationPageTitle</h1>

    @if (!string.IsNullOrEmpty(_message))
    {
        <p class="@(_isError ? "message-error" : "message-success")">@_message</p>
    }

    <input type="email" placeholder="@Loc.EmailPlaceholder" @bind="_email" @bind:event="oninput" />
    <input type="password" placeholder="@Loc.PasswordPlaceholder" @bind="_password" @bind:event="oninput" />
    <input type="password" placeholder="@Loc.PasswordRepeatPlaceholder" @bind="_passwordRepeat" @bind:event="oninput" />
    <input placeholder="@Loc.FirstNamePlaceholder" @bind="_firstName" @bind:event="oninput" />
    <input placeholder="@Loc.LastNamePlaceholder" @bind="_lastName" @bind:event="oninput" />

    <button @onclick="OnRegisterNowClicked">@Loc.RegisterNowButtonText</button>
</div>

@code {
    private string _email = string.Empty;
    private string _password = string.Empty;
    private string _passwordRepeat = string.Empty;
    private string _firstName = string.Empty;
    private string _lastName = string.Empty;
    private string? _message;
    private bool _isError;

    protected override void OnInitialized()
    {
        Loc.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        Loc.OnChange -= StateHasChanged;
    }

    private async Task OnRegisterNowClicked()
    {
        if (_password != _passwordRepeat)
        {
            _isError = true;
            _message = Loc.PasswordMismatchMessage;
            return;
        }

        var response = await Http.PostAsJsonAsync("api/users/register", new RegisterRequest(
            _email.Trim(), _password, _passwordRepeat, _firstName.Trim(), _lastName.Trim()));

        var result = await response.Content.ReadFromJsonAsync<RegisterResponse>();

        switch (result?.Status)
        {
            case RegisterStatus.EmailAlreadyRegistered:
                _isError = true;
                _message = Loc.EmailAlreadyRegisteredMessage;
                break;
            case RegisterStatus.PasswordMismatch:
                _isError = true;
                _message = Loc.PasswordMismatchMessage;
                break;
            case RegisterStatus.Success:
                _isError = false;
                _message = Loc.RegistrationSuccessMessage;
                break;
        }
    }
}
