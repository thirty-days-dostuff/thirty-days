@page "/profile"
@attribute [Authorize]
@using System.Security.Claims
@inject HttpClient Http

<PageTitle>Profile</PageTitle>

<h1>Profile</h1>

<AuthorizeView>
    <Authorized>
        <p><strong>Name:</strong> @context.User.Identity?.Name</p>
        <p><strong>Email:</strong> @context.User.FindFirst(ClaimTypes.Email)?.Value</p>

        @if (_dbProfile is not null)
        {
            <h2>Local profile</h2>
            <p><strong>First name:</strong> @_dbProfile.FirstName</p>
            <p><strong>Last name:</strong> @_dbProfile.LastName</p>
        }
    </Authorized>
</AuthorizeView>

@code {
    private UserProfileResponse? _dbProfile;

    protected override async Task OnInitializedAsync()
    {
        _dbProfile = await Http.GetFromJsonAsync<UserProfileResponse>("api/users/me");
    }
}
