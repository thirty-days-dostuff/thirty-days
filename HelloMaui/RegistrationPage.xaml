<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:HelloMaui.Localization"
             x:Class="HelloMaui.RegistrationPage"
             Title="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=RegistrationPageTitle}">

    <VerticalStackLayout VerticalOptions="Center">
        <Label
            Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=RegistrationPageTitle}"
            Style="{StaticResource Headline}"
            SemanticProperties.HeadingLevel="Level1" />
    </VerticalStackLayout>

</ContentPage>
