<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:HelloMaui.Localization"
             x:Class="HelloMaui.StartPage"
             Title="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=StartPageTitle}">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="16"
            VerticalOptions="Center">

            <Picker
                x:Name="LanguagePicker"
                Title="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=LanguagePickerTitle}"
                SelectedIndexChanged="OnLanguageChanged"
                HorizontalOptions="Fill">
                <Picker.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>Deutsch</x:String>
                        <x:String>English</x:String>
                    </x:Array>
                </Picker.ItemsSource>
            </Picker>

            <Label
                Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=StartPageTitle}"
                Style="{StaticResource Headline}"
                SemanticProperties.HeadingLevel="Level1" />

            <Entry
                x:Name="EmailEntry"
                Placeholder="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=EmailPlaceholder}"
                Keyboard="Email"
                TextChanged="OnCredentialsTextChanged"
                SemanticProperties.Hint="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=EmailPlaceholder}" />

            <Entry
                x:Name="PasswordEntry"
                Placeholder="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=PasswordPlaceholder}"
                IsPassword="True"
                TextChanged="OnCredentialsTextChanged"
                SemanticProperties.Hint="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=PasswordPlaceholder}" />

            <Button
                x:Name="LoginButton"
                Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=LoginButtonText}"
                Clicked="OnLoginClicked"
                IsEnabled="False"
                HorizontalOptions="Fill" />

            <Button
                x:Name="ForgotPasswordButton"
                Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=ForgotPasswordButtonText}"
                Clicked="OnForgotPasswordClicked"
                BackgroundColor="Transparent"
                TextColor="{StaticResource Primary}"
                HorizontalOptions="Fill" />

            <Button
                x:Name="RegisterButton"
                Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=RegisterButtonText}"
                Clicked="OnRegisterClicked"
                HorizontalOptions="Fill" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
